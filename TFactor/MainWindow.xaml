<Window x:Class="TFactor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TFactor"
        xmlns:properties="clr-namespace:TFactor.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Strings.Common_AppTitle}" Height="760" Width="280" MinWidth="280" MaxWidth="280"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Icon="Icons/icon.ico"
        Background="{StaticResource Brush.Background}">
    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button x:Name="AddAccountButton"
                    DockPanel.Dock="Left"
                    Width="32"
                    Height="32"
                    Margin="0,0,8,0"
                    ToolTip="{x:Static properties:Strings.MainWindow_AddAccountTooltip}"
                    Click="AddAccount_Click">
                <Image Source="Icons/add.png" Stretch="Uniform" />
            </Button>
            <Button x:Name="ImportButton" DockPanel.Dock="Left" Width="32" Height="32" Margin="0,0,8,0" ToolTip="{x:Static properties:Strings.MainWindow_ImportTooltip}" Click="ImportFromScreenshot_Click">
                <Image Source="Icons/import.png" Stretch="Uniform" />
            </Button>

            <Grid VerticalAlignment="Center">
                <TextBox x:Name="SearchBox"
                         Width="150"
                         Height="26"
                         Padding="3,0"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged" />
            </Grid>
        </DockPanel>

        <TextBlock x:Name="EmptyMessage"
                    DockPanel.Dock="Bottom"
                    Text="{x:Static properties:Strings.MainWindow_EmptyMessage}"
                    TextWrapping="Wrap"
                    Foreground="{StaticResource Brush.TextSecondary}"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"
                    Visibility="Collapsed" />

        <ListBox x:Name="AccountList"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 PreviewMouseWheel="AccountList_PreviewMouseWheel">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Issuer}" FontWeight="Bold" FontSize="14" />
                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource Brush.TextTeal}" FontSize="12" />
                                <Button Margin="0,4,0,0"
                                        Padding="6,2"
                                        HorizontalAlignment="Left"
                                        ToolTip="{x:Static properties:Strings.MainWindow_CodeTooltip}"
                                        Click="Code_Click">
                                    <TextBlock Text="{Binding Code}"
                                               FontSize="26"
                                               Foreground="{StaticResource Brush.AccentBlue}" />
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding SecondsRemaining, StringFormat={}{0}s}"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{Binding SecondsRemaining, Converter={StaticResource SecondsRemainingToBrushConverter}}" />
                                <Button Width="32"
                                        Height="32"
                                        Tag="{Binding}"
                                        Click="EditAccount_Click"
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Center"
                                        ToolTip="{x:Static properties:Strings.MainWindow_EditTooltip}">
                                    <Image Source="Icons/edit.png" Stretch="Uniform" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
