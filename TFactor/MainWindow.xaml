<Window x:Class="TFactor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TFactor"
        mc:Ignorable="d"
        Title="TFactor" Height="760" Width="280" MinWidth="280"
        ResizeMode="CanResize"
        Icon="Icons/icon.ico"
        Background="{StaticResource Brush.Background}">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="AddAccountButton"
                    Width="32"
                    Height="32"
                    Margin="0,0,8,0"
                    ToolTip="Add Account"
                    Click="AddAccount_Click">
                <Image Source="Icons/add.png" Stretch="Uniform" />
            </Button>
            <Button x:Name="ImportButton" Width="32" Height="32" ToolTip="Import from Screenshot" Click="ImportFromScreenshot_Click">
                <Image Source="Icons/import.png" Stretch="Uniform" />
            </Button>
        </StackPanel>

        <TextBlock x:Name="EmptyMessage"
                    DockPanel.Dock="Bottom"
                    Text="No accounts yet. Add one, or import from a Google Authenticator screenshot."
                    TextWrapping="Wrap"
                    Foreground="{StaticResource Brush.TextSecondary}"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"
                    Visibility="Collapsed" />

        <ListBox x:Name="AccountList"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 PreviewMouseWheel="AccountList_PreviewMouseWheel">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Issuer}" FontWeight="Bold" FontSize="14" />
                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource Brush.TextTeal}" FontSize="12" />
                                <TextBlock Text="{Binding Code}"
                                           FontSize="26"
                                           Foreground="{StaticResource Brush.AccentBlue}"
                                           Margin="0,4,0,0"
                                           Cursor="Hand"
                                           ToolTip="Click to copy"
                                           MouseLeftButtonUp="Code_Click" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding SecondsRemaining, StringFormat={}{0}s}"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{StaticResource Brush.TextTeal}" />
                                <Button Width="32"
                                        Height="32"
                                        Tag="{Binding}"
                                        Click="EditAccount_Click"
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Center"
                                        ToolTip="Edit">
                                    <Image Source="Icons/edit.png" Stretch="Uniform" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
