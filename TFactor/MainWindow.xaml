<Window x:Class="TFactor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TFactor"
        mc:Ignorable="d"
        Title="TFactor" Height="500" Width="380" MinWidth="320">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="AddAccountButton" Content="Add Account" Padding="10,5" Margin="0,0,8,0" Click="AddAccount_Click" />
            <Button x:Name="ImportButton" Content="Import from Screenshot" Padding="10,5" Click="ImportFromScreenshot_Click" />
        </StackPanel>

        <TextBlock x:Name="EmptyMessage"
                    DockPanel.Dock="Bottom"
                    Text="No accounts yet. Add one, or import from a Google Authenticator screenshot."
                    TextWrapping="Wrap"
                    Foreground="Gray"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"
                    Visibility="Collapsed" />

        <ListBox x:Name="AccountList" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Issuer}" FontWeight="Bold" FontSize="14" />
                                <TextBlock Text="{Binding Label}" Foreground="Gray" FontSize="12" />
                                <TextBlock Text="{Binding Code}"
                                           FontSize="26"
                                           FontFamily="Consolas"
                                           Margin="0,4,0,0"
                                           Cursor="Hand"
                                           ToolTip="Click to copy"
                                           MouseLeftButtonUp="Code_Click" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding SecondsRemaining, StringFormat={}{0}s}"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           Foreground="Gray" />
                                <Button Content="Remove"
                                        Tag="{Binding}"
                                        Click="DeleteAccount_Click"
                                        Margin="0,6,0,0"
                                        Padding="6,2"
                                        FontSize="10" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
