<Window x:Class="TFactor.ManageTagsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TFactor"
        xmlns:properties="clr-namespace:TFactor.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Strings.ManageTagsWindow_Title}" Height="400" Width="300"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Brush.Background}">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="32" Height="32" Margin="0,0,8,0" ToolTip="{x:Static properties:Strings.Common_CancelTooltip}" Click="Cancel_Click">
                <Image Source="Icons/cancel.png" Stretch="Uniform" />
            </Button>
            <Button Width="32" Height="32" ToolTip="{x:Static properties:Strings.Common_SaveTooltip}" Click="Save_Click" IsDefault="True">
                <Image Source="Icons/save.png" Stretch="Uniform" />
            </Button>
        </StackPanel>

        <!-- "Untagged" always sorts first and isn't reorderable, so it's shown once here, separate from the reorderable list below -->
        <TextBlock DockPanel.Dock="Top" Text="{x:Static properties:Strings.Common_UntaggedLabel}" FontWeight="Bold" FontSize="13" Margin="0,0,0,8" />
        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Margin="0,0,0,10" />

        <ListBox x:Name="TagList">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" FontSize="13" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Width="24"
                                    Height="24"
                                    Margin="0,0,4,0"
                                    ToolTip="{x:Static properties:Strings.ManageTagsWindow_MoveUpTooltip}"
                                    Tag="{Binding}"
                                    Click="MoveUp_Click">
                                <TextBlock Text="&#9650;" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Brush.AccentBlue}" />
                            </Button>
                            <Button Width="24"
                                    Height="24"
                                    ToolTip="{x:Static properties:Strings.ManageTagsWindow_MoveDownTooltip}"
                                    Tag="{Binding}"
                                    Click="MoveDown_Click">
                                <TextBlock Text="&#9660;" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Brush.AccentBlue}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
