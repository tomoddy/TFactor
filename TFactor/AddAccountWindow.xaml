<Window x:Class="TFactor.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TFactor"
        mc:Ignorable="d"
        Title="Add Account" Height="420" Width="340"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Issuer" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="IssuerTextBox" Margin="0,0,0,12" />

        <TextBlock Text="Label" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="LabelTextBox" Margin="0,0,0,12" />

        <TextBlock Text="Secret Key" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox x:Name="SecretTextBox" Margin="0,0,0,12" FontFamily="Consolas" />

        <TextBlock Text="Algorithm" FontWeight="Bold" Margin="0,0,0,4" />
        <ComboBox x:Name="AlgorithmComboBox" Margin="0,0,0,12" SelectedIndex="0">
            <ComboBoxItem Content="SHA1" />
            <ComboBoxItem Content="SHA256" />
            <ComboBoxItem Content="SHA512" />
        </ComboBox>

        <TextBlock Text="Digits" FontWeight="Bold" Margin="0,0,0,4" />
        <ComboBox x:Name="DigitsComboBox" Margin="0,0,0,12" SelectedIndex="0">
            <ComboBoxItem Content="6" />
            <ComboBoxItem Content="8" />
        </ComboBox>

        <TextBlock x:Name="ErrorTextBlock"
                    Foreground="Red"
                    TextWrapping="Wrap"
                    Margin="0,0,0,8"
                    Visibility="Collapsed" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Padding="12,5" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Save" Padding="12,5" Click="Save_Click" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</Window>
