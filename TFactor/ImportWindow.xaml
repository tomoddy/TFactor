<Window x:Class="TFactor.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TFactor"
        mc:Ignorable="d"
        Title="Import from Screenshot" Height="480" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Background}">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top"
                    TextWrapping="Wrap"
                    Margin="0,0,0,12"
                    Text="Choose either a single account's QR code or Google Authenticator's 'Transfer accounts' export QR code. If your export used more than one QR code, choose each screenshot in turn - they'll all be added below." />

        <Button x:Name="ChooseFileButton"
                DockPanel.Dock="Top"
                Width="32"
                Height="32"
                HorizontalAlignment="Left"
                Margin="0,0,0,12"
                ToolTip="Choose Screenshot..."
                Click="ChooseFile_Click">
            <Image Source="Icons/import.png" Stretch="Uniform" />
        </Button>

        <TextBlock x:Name="ErrorTextBlock"
                    DockPanel.Dock="Top"
                    Foreground="{StaticResource Brush.AccentPink}"
                    TextWrapping="Wrap"
                    Margin="0,0,0,12"
                    Visibility="Collapsed" />

        <TextBlock x:Name="StatusTextBlock"
                    DockPanel.Dock="Top"
                    Foreground="{StaticResource Brush.AccentYellow}"
                    TextWrapping="Wrap"
                    Margin="0,0,0,12"
                    Visibility="Collapsed" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="32" Height="32" Margin="0,0,8,0" ToolTip="Cancel" Click="Cancel_Click">
                <Image Source="Icons/cancel.png" Stretch="Uniform" />
            </Button>
            <Button x:Name="ImportButton"
                    Width="32"
                    Height="32"
                    IsEnabled="False"
                    ToolTip="Import Selected"
                    Click="Import_Click">
                <Image Source="Icons/save.png" Stretch="Uniform" />
            </Button>
        </StackPanel>

        <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="6">
            <ListBox x:Name="CandidateList">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="8,6">
                            <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <StackPanel>
                                <TextBlock Text="{Binding Issuer}" FontWeight="Bold" />
                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource Brush.TextTeal}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</Window>
