<Window x:Class="TFactor.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TFactor"
        mc:Ignorable="d"
        Title="Import from Screenshot" Height="480" Width="380"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top"
                    TextWrapping="Wrap"
                    Margin="0,0,0,12"
                    Text="Choose either a single account's QR code or Google Authenticator's 'Transfer accounts' export QR code." />

        <Button DockPanel.Dock="Top"
                Content="Choose Screenshot..."
                Padding="10,5"
                HorizontalAlignment="Left"
                Margin="0,0,0,12"
                Click="ChooseFile_Click" />

        <TextBlock x:Name="ErrorTextBlock"
                    DockPanel.Dock="Top"
                    Foreground="Red"
                    TextWrapping="Wrap"
                    Margin="0,0,0,12"
                    Visibility="Collapsed" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="12,5" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button x:Name="ImportButton" Content="Import Selected" Padding="12,5" IsEnabled="False" Click="Import_Click" />
        </StackPanel>

        <ListBox x:Name="CandidateList" BorderThickness="1" BorderBrush="#DDDDDD">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <StackPanel>
                            <TextBlock Text="{Binding Issuer}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Label}" Foreground="Gray" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
